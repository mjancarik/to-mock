{
  "name": "to-mock",
  "version": "1.6.2",
  "description": "The utility to mock class and objects. You can use mocked classes and objects for your unit and integration tests",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node_modules/.bin/tsup",
    "dev": "node_modules/.bin/tsup --watch",
    "lint": "biome check --no-errors-on-unmatched",
    "lint:fix": "npm run lint -- --fix --unsafe",
    "test": "node --test --experimental-test-snapshots ./src/__tests__/toMockSpec.node.mjs",
    "vitest": "vitest run",
    "preversion": "npm test && npm run lint && npm run build",
    "postversion": "npm run changelog && git commit -am $npm_package_version && git tag $npm_package_version && git push && git push --tags && npm publish",
    "prepare": "husky",
    "commit": "node_modules/.bin/git-cz",
    "changelog": "node_modules/.bin/conventional-changelog -p angular -i CHANGELOG.md -s -r 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mjancarik/to-mock.git"
  },
  "keywords": [
    "mock",
    "unit",
    "tests",
    "integration",
    "test",
    "typescript",
    "javascript",
    "ES6",
    "class",
    "object",
    "jest",
    "jasmine",
    "mocha",
    "tape",
    "ava"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "author": "Miroslav Jancarik",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mjancarik/to-mock/issues"
  },
  "homepage": "https://github.com/mjancarik/to-mock#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "**/*.{mjs,json}": "npm run lint"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
